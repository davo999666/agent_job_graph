{
  "manifest_version": 3,
  "name": "Job CV Matcher",
  "version": "1.1",
  "description": "Send job descriptions to FastAPI",

  "host_permissions": [
    "http://127.0.0.1:8000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*",
        "*://*.drushim.co.il/*",
        "*://*.yad2.co.il/*"
      ],
      "js": [
        "modal/modal_window.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}